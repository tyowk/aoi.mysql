{
    "name": "aoi.mysql",
    "version": "3.0.0",
    "description": "Implementation of MySQL in Aoi.js",
    "type": "commonjs",
    "main": "dist/CJS/index.js",
    "module": "dist/ESM/index.js",
    "types": "dist/CJS/types/index.d.ts",
    "export": {
        "import": {
            "default": "./dist/ESM/index.js",
            "types": "./dist/ESM/types/index.d.ts"
        },
        "require": {
            "default": "./dist/CJS/index.js",
            "types": "./dist/CJS/types/index.d.ts"
        }
    },
    "scripts": {
        "start": "npm run build",
        "build": "npm run build:cjs && npm run build:esm",
        "build:esm": "tsc -p tscoesm.json && echo Building ESM Done!",
        "build:cjs": "tsc -p tsconfig.json && echo Building CJS Done!"
    },
    "keywords": [
        "discord.js",
        "aoi.js",
        "aoi.db",
        "mysql",
        "mysql2",
        "database",
        "bdfd"
    ],
    "author": "Tyowk <tyowk@outlook.com>",
    "license": "MIT",
    "dependencies": {
        "mysql2": "^3.11.3"
    },
    "devDependencies": {
        "aoi.js": "^6.9.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tyowk/aoi.mysql.git"
    },
    "bugs": {
        "url": "https://github.com/tyowk/aoi.mysql/issues"
    },
    "homepage": "https://aoi.js.org",
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "package.json"
    ]
}
